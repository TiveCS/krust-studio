# Flat, symlink-free node_modules so electron-builder can find every transitive
# dependency (e.g. electron-updater → builder-util-runtime → debug → ms) when
# packing the asar. `shamefully-hoist` alone leaves pnpm's symlinked store,
# which electron-builder mis-walks for deep transitive deps.
node-linker=hoisted
shamefully-hoist=true
